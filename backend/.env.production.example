# Production Environment Variables for Render.com
# Copy and paste these values into Render dashboard environment variables

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5000
NODE_ENV=production

# ============================================
# DATABASE CONFIGURATION - Supabase Direct Connection
# ============================================
# Using individual parameters (more reliable than connection string on Render)
DB_HOST=db.pkupecytvrxggjrngkdf.supabase.co
DB_USER=postgres
DB_PASSWORD=pateladitya3700starsProject
DB_NAME=postgres
DB_PORT=5432
DB_SSL=true

# ============================================
# JWT CONFIGURATION
# ============================================
# SECURITY: Generate a new strong random secret for production
# Run this command to generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Then replace the value below
JWT_SECRET=your-generated-random-secret-key-here-min-32-chars
JWT_EXPIRE=7d

# ============================================
# CORS CONFIGURATION
# ============================================
# IMPORTANT: Update with your actual Render frontend URL
# Format: https://your-app-name.onrender.com
# For multiple URLs, use comma-separated: https://frontend1.onrender.com,https://frontend2.onrender.com
CORS_ORIGIN=https://your-frontend-app.onrender.com

# ============================================
# FRONTEND URL (for reference)
# ============================================
FRONTEND_URL=https://your-frontend-app.onrender.com

# ============================================
# OPTIONAL: Supabase API Keys (not used by backend, for reference only)
# ============================================
# SUPABASE_URL=https://pkupecytvrxggjrngkdf.supabase.co
# SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InBrdXBlY3l0dnJ4Z2dqcm5na2RmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQyODM2ODcsImV4cCI6MjA4OTg1OTY4N30.rUHjOAb73OXa_2mMYInrlwJd5bTKJwot36IklLGLfj4

# ============================================
# RENDER DEPLOYMENT CHECKLIST
# ============================================
# 1. ✅ DATABASE_URL - Already configured with pooler
# 2. ⚠️  JWT_SECRET - Generate new random string (see instructions above)
# 3. ⚠️  CORS_ORIGIN - Update to your Render frontend URL
# 4. ⚠️  FRONTEND_URL - Update to your Render frontend URL
# 5. Copy all variables to Render dashboard
# 6. Deploy backend
# 7. Test health endpoint: https://your-backend.onrender.com/health
# 8. Test login: POST https://your-backend.onrender.com/api/auth/login

# ============================================
# HOW TO GENERATE JWT_SECRET
# ============================================
# Run this in your terminal:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Copy the output and paste it as JWT_SECRET value

